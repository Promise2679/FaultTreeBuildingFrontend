    "@nuxt/eslint": "catalog:nuxt",
    "@promise2/eslint-config": "catalog:infra",
    "@vueuse/nuxt": "catalog:nuxt",
    "eslint": "catalog:",
    "nano-staged": "catalog:infra",
    "simple-git-hooks": "catalog:infra",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vue-tsc": "catalog:nuxt"
  },
  "packageManager": "pnpm@10.30.3"
